# Copy to .env — MyChatApp local Docker

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=mychatapp
POSTGRES_USER=mychatapp
POSTGRES_PASSWORD=mychatapp_local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/mychatapp
SPRING_DATASOURCE_USERNAME=mychatapp
SPRING_DATASOURCE_PASSWORD=mychatapp_local

# Phải trùng region bucket S3 (CDK deploy, thường ap-southeast-1)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
MEDIA_PUBLIC_BASE_URL=
MAGIKA_SERVICE_URL=http://localhost:8090
MAGIKA_REQUEST_TIMEOUT_MS=10000
# Retry HTTP -> magika-service (transient: timeout, 502/503/504/429); delay 3-5s jitter
MAGIKA_RETRY_MAX_ATTEMPTS=3
MAGIKA_RETRY_DELAY_MIN_MS=3000
MAGIKA_RETRY_DELAY_MAX_MS=5000
MAGIKA_STARTUP_RETRY_MAX_ATTEMPTS=10
# Client rate limit: outbound magika /identify only (not /health); in-memory per process
MAGIKA_CLIENT_RATE_LIMIT_MAX=5
MAGIKA_CLIENT_RATE_LIMIT_WINDOW_MS=60000
# AWS SDK retry for S3 presign (exponential backoff, not fixed 3-5s)
AWS_SDK_MAX_ATTEMPTS=3
# MEDIA_UPLOAD_CONFIG_PATH=path/to/media-upload.config.json
# Kich thuoc mau fileHead: media-service/media-upload.config.json -> fileHeadMaxBytes
# true = bo qua Magika neu magic bytes da khop extension (nhanh hon)
MEDIA_MAGIKA_SKIP_ON_MAGIC_MATCH=true
# 0 = khong kiem tra score; vi du 0.5 neu can
MEDIA_MAGIKA_MIN_CONFIDENCE=0
# Chi khi dev DynamoDB Local (docker): DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE=MyChatApp_Chat

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Valkey (space-based chat) — local Docker; production: ElastiCache for Valkey endpoint
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_SSL_ENABLED=false

# API Gateway distributed rate limit (Valkey) — fail-open when false
GATEWAY_RATELIMIT_ENABLED=false
GATEWAY_RATELIMIT_AUTH_REPLENISH=5
GATEWAY_RATELIMIT_AUTH_BURST=10
GATEWAY_RATELIMIT_MEDIA_REPLENISH=10
GATEWAY_RATELIMIT_MEDIA_BURST=20
GATEWAY_RATELIMIT_DEFAULT_REPLENISH=50
GATEWAY_RATELIMIT_DEFAULT_BURST=100
GATEWAY_RATELIMIT_WS_REPLENISH=50
GATEWAY_RATELIMIT_WS_BURST=100

CHAT_SPACE_TIMELINE_MAX_SIZE=300
CHAT_SPACE_DEFAULT_PAGE_SIZE=10
CHAT_SPACE_HYDRATE_BATCH_SIZE=10
CHAT_SPACE_ENABLED=true
# false = DynamoDB qua RabbitMQ async; true = ghi DynamoDB dong thoi khi gui (debug / dam bao persist FILE)
CHAT_SPACE_DUAL_WRITE_DYNAMODB=false
# Outbox (chat-service) — durable event truoc RabbitMQ; false = publish truc tiep nhu cu
CHAT_OUTBOX_ENABLED=true
# CHAT_OUTBOX_POLL_INTERVAL_MS=3000
# CHAT_OUTBOX_BATCH_SIZE=50
# CHAT_OUTBOX_MAX_PUBLISH_ATTEMPTS=20

# RabbitMQ internal (chat-service persist + hydrate)
RABBITMQ_CHAT_INTERNAL_EXCHANGE=chat.internal
RABBITMQ_CHAT_PERSIST_QUEUE=chat.persist.queue
RABBITMQ_CHAT_PERSIST_ROUTING_KEY=chat.message.created
RABBITMQ_CHAT_HYDRATE_QUEUE=chat.hydrate.queue
RABBITMQ_CHAT_HYDRATE_ROUTING_KEY=chat.history.load
RABBITMQ_CHAT_UPDATED_ROUTING_KEY=chat.message.updated
# DLQ cho poison message (chat-service) — optional, co default trong application.yml
# RABBITMQ_CHAT_INTERNAL_DLX=chat.internal.dlx
# RABBITMQ_CHAT_PERSIST_DLQ=chat.persist.dlq
# RABBITMQ_CHAT_PERSIST_DLQ_ROUTING_KEY=chat.persist.dlq
# RABBITMQ_CHAT_HYDRATE_DLQ=chat.hydrate.dlq
# RABBITMQ_CHAT_HYDRATE_DLQ_ROUTING_KEY=chat.hydrate.dlq
# Listener retry (chat-service) — optional
# RABBITMQ_LISTENER_RETRY_MAX_ATTEMPTS=5
# RABBITMQ_LISTENER_RETRY_INITIAL_INTERVAL=2s
# RABBITMQ_LISTENER_RETRY_MULTIPLIER=2.0
# RABBITMQ_LISTENER_RETRY_MAX_INTERVAL=30s
# true khi chay nhieu instance chat-service; local 1 instance de false
CHAT_SPACE_REDIS_FANOUT_ENABLED=false

JWT_SECRET=dev-local-jwt-secret-change-before-production-min-32-chars
JWT_EXPIRATION=3600000

SERVER_PORT=8080
AUTH_SERVICE_PORT=8081
CHAT_SERVICE_PORT=8082
# STOMP/SockJS (Spring WebSocket) — chat-service
WEBSOCKET_ENDPOINT=/ws
WEBSOCKET_SOCKJS_ENABLED=true
WEBSOCKET_ALLOWED_ORIGINS=https://*.vercel.app,http://localhost:3000,https://chat.oeb20412.com

# Comma-separated origin patterns (Spring allowedOriginPatterns) — API Gateway CORS
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,https://*.vercel.app,https://chat.oeb20412.com
WEBSOCKET_TOPIC_PREFIX=/topic
WEBSOCKET_APP_PREFIX=/app
USER_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
MEDIA_SERVICE_PORT=8085

AUTH_SERVICE_URI=http://localhost:8081
CHAT_SERVICE_URI=http://localhost:8082
USER_SERVICE_URI=http://localhost:8083
NOTIFICATION_SERVICE_URI=http://localhost:8084
MEDIA_SERVICE_URI=http://localhost:8085

RABBITMQ_EXCHANGE=auth.exchange
RABBITMQ_ROUTING_KEY=auth.registered
RABBITMQ_PROFILE_QUEUE=profile-create.queue
RABBITMQ_FRIEND_EXCHANGE=friend.exchange
RABBITMQ_FRIEND_REQUEST_ROUTING_KEY=friend.request.sent
RABBITMQ_FRIEND_ACCEPTED_ROUTING_KEY=friend.request.accepted
RABBITMQ_CHAT_EXCHANGE=chat.exchange
RABBITMQ_CHAT_ROUTING_KEY=chat.message.sent
RABBITMQ_CHAT_QUEUE=chat.notification.queue
RABBITMQ_PRESENCE_EXCHANGE=presence.exchange
RABBITMQ_PRESENCE_CHANGED_ROUTING_KEY=user.presence.changed
RABBITMQ_PRESENCE_CHANGED_QUEUE=user.presence.changed.queue
RABBITMQ_PRESENCE_NOTIFY_ROUTING_KEY=user.presence.notify
RABBITMQ_PRESENCE_NOTIFY_QUEUE=chat.presence.notify.queue
RABBITMQ_MAIL_EXCHANGE=auth.exchange
RABBITMQ_MAIL_QUEUE=mail.queue
RABBITMQ_MAIL_ROUTING_KEY=auth.registered
RABBITMQ_LOGIN_OTP_ROUTING_KEY=auth.login-otp
RABBITMQ_LOGIN_OTP_QUEUE=auth.login-otp.queue
RABBITMQ_PASSWORD_RESET_ROUTING_KEY=auth.password-reset
RABBITMQ_PASSWORD_RESET_QUEUE=auth.password-reset.queue
RABBITMQ_PASSWORD_RESET_CONFIRMATION_ROUTING_KEY=auth.password-reset-confirmed
RABBITMQ_PASSWORD_RESET_CONFIRMATION_QUEUE=auth.password-reset-confirmed.queue

OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=3
PASSWORD_RESET_RESET_LINK=http://localhost:5173/reset-password
MAIL_REGISTRATION_ENABLED=false

# Amazon SES API (domain đã verify; IAM cần ses:SendEmail)
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=MyChatApp

MONGODB_URI=

# --- AWS production (sau CDK deploy: .\scripts\sync-cdk-env.ps1) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://<rds-host>:5432/mychatapp
# AWS_REGION=ap-southeast-1
# DYNAMODB_TABLE=MyChatApp_Chat   (tu output DynamoDbTableName)
# (khong set DYNAMODB_ENDPOINT — chat-service tu ket noi AWS DynamoDB)
