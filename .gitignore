# =============================================================================
# MyChatApp Back-End — root .gitignore (monorepo)
# Copy env từ *.example; không commit secret / build output.
# =============================================================================

# --- Environment & secrets ---
.env
.env.*
!.env.example
!.env.*.example
DockerTest/.env.docker

# --- Maven (Spring Boot microservices) ---
**/target/
**/.mvn/wrapper/maven-wrapper.jar
HELP.md
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# --- Node.js (media-service, infra/cdk, …) ---
**/node_modules/
**/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# --- AWS CDK ---
**/cdk.out/
infra/cdk/cdk.context.json

# --- TypeScript build (CDK app — giữ *.ts, bỏ output biên dịch) ---
infra/cdk/*.js
infra/cdk/*.d.ts

# --- Python (magika-service) ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/.pytest_cache/
**/*.egg-info/

# --- Dev scripts (generated launchers) ---
scripts/.launchers/*.ps1
!scripts/.launchers/.gitignore

# --- Logs & temp ---
**/*.log
logs/
*.tmp
*.bak
.cache/

# --- IDE ---
.idea/
**/*.iml
**/*.iws
**/*.ipr
.vscode/
.classpath
.project
.settings/
.sts4-cache/
.apt_generated
.factorypath
.springBeans

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Test / coverage (nếu có) ---
coverage/
.nyc_output/
**/surefire-reports/
**/failsafe-reports/
