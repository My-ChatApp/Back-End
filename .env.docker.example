# Copy -> .env.docker (cùng thư mục Back-End-NDuy)
# Dùng với: docker compose -f docker-compose.yml -f docker-compose.apps.yml --env-file .env.docker up -d

IMAGE_TAG=v1

SPRING_DATASOURCE_USERNAME=mychatapp
SPRING_DATASOURCE_PASSWORD=mychatapp_local

JWT_SECRET=dev-local-jwt-secret-change-before-production-min-32-chars
JWT_EXPIRATION=3600000

# DynamoDB AWS (copy AWS_* từ .env nếu đã deploy CDK)
DYNAMODB_TABLE=MyChatApp_Chat
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

SPRING_DATA_REDIS_SSL_ENABLED=false

CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,https://*.vercel.app
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app

# media-service — copy S3_BUCKET, MEDIA_PUBLIC_BASE_URL từ .env sau CDK deploy
S3_BUCKET=
MEDIA_PUBLIC_BASE_URL=http://localhost:8080

GATEWAY_RATELIMIT_ENABLED=false

# agent-service (Groq) — copy GROQ_API_KEY từ .env nếu đã có
GROQ_API_KEY=
